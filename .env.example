# Core service
APP_NAME=Financial Multimodal Assistant
APP_ENV=development
LOG_LEVEL=INFO
FINANCE_GUARDRAILS_ENABLED=false

# API server
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
STREAMLIT_BACKEND_URL=http://localhost:8000

# Storage
DATA_DIR=./data
UPLOAD_DIR=./data/uploads
DOCUMENT_DIR=./data/documents
CHROMA_DIR=./data/chroma

# LLM / AI
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EXTRACTION_USE_LLM=false
MAX_UPLOAD_SIZE_MB=20
DOCLING_ENABLED=true
DOCLING_FOR_PDF=false

# Optional OCR configuration (Windows example)
# TESSERACT_CMD=C:\\Program Files\\Tesseract-OCR\\tesseract.exe
TESSERACT_CMD=

# LangSmith observability
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=financial-doc-assistant
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# RAG defaults
RAG_TOP_K=5
CHUNK_SIZE=900
CHUNK_OVERLAP=120
MAX_CHUNKS_PER_DOCUMENT=250

# Caching
RESPONSE_CACHE_ENABLED=true
RESPONSE_CACHE_TTL_SECONDS=300
RESPONSE_CACHE_MAX_ENTRIES=512
RETRIEVAL_CACHE_ENABLED=true
RETRIEVAL_CACHE_TTL_SECONDS=180
RETRIEVAL_CACHE_MAX_ENTRIES=1024
REPOSITORY_CACHE_TTL_SECONDS=120
REPOSITORY_CACHE_MAX_ENTRIES=1024

# Anomaly detection
ANOMALY_HIGH_TOTAL_THRESHOLD=5000.0
ANOMALY_HIGH_TAX_RATIO=0.35
ANOMALY_LINE_TOTAL_MISMATCH_RATIO=0.2
ANOMALY_ROBUST_Z_THRESHOLD=3.5
ANOMALY_HISTORY_LIMIT=80
